  m_Script: {fileID: 11500000, guid: b7728220ac44fa64f975739a31146383, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HintZone
  message: "Buenos dias, Sujeto nro. 580. Te encuentras en el a\xF1o 3000 y la humanidad
    ah sido aniquilada por las m\xE1quinas y su potente ia, hoy te encuentras en
    un campo de pruebas... quieres ganarte tu libertad? Vale siquiera la pena? diria
    que no hay nada afuera de estas instalaciones... pero si insistes... seras libre
    cuando superes todas y cada una de las pruebas. Los controles son los de siempre
    WASD y saltas con SPACE e interactuas con la E."
  triggerRange: 1.23
